# ============================================
# LLM PROVIDER CONFIGURATION
# ============================================
# Select which LLM provider to use for chat responses and intent analysis
# Options: deepseek (default), minimax
LLM_PROVIDER=deepseek

# DeepSeek LLM Configuration
# Get your API key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/v1/chat/completions

# MiniMax LLM Configuration (NOTE: Use the SAME key as IMAGE analysis)
# Get your API key at: https://platform.minimax.io/
# The same MINIMAX_API_KEY and MINIMAX_GROUP_ID work for both LLM chat and image analysis
# See IMAGE ANALYSIS CONFIGURATION section below for MINIMAX_API_KEY and MINIMAX_GROUP_ID
# MINIMAX_MODEL=MiniMax-M2.7

# ============================================
# IMAGE ANALYSIS CONFIGURATION
# ============================================
# Select which provider to use for image analysis
# Options: minimax (default), openai, deepseek (future)
IMAGE_PROVIDER=minimax

# MiniMax Vision API (PRIMARY - Recommended)
# Get your credentials at: https://platform.minimax.chat/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# OpenAI GPT-4 Vision (ALTERNATIVE - Premium option)
# Get your API key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_VISION_MODEL=gpt-4o  # Options: gpt-4o, gpt-4-turbo

# DeepSeek Vision (FUTURE - Not yet available)
# Uses the same key as DEEPSEEK_API_KEY
# DeepSeek does not currently support vision/image analysis
# DEEPSEEK_VISION_MODEL=deepseek-chat

# Image Analysis Settings
# Maximum tokens for analysis response (default: 500)
# IMAGE_MAX_TOKENS=500

# Enable fallback to alternative provider if primary fails (default: true)
# IMAGE_FALLBACK_ENABLED=true

# Fallback provider when primary fails (default: openai)
# IMAGE_FALLBACK_PROVIDER=openai

# Timeout for image analysis in milliseconds (default: 30000)
# IMAGE_TIMEOUT=30000

# Enable verbose logging for image analysis (default: false)
# IMAGE_VERBOSE=false

# ============================================
# PLATFORM SELECTION
# ============================================
# Set to "whatsapp" or "messenger"
PLATFORM=messenger

# Facebook Messenger Configuration (required for messenger platform)
PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
VERIFY_TOKEN=your_verify_token_here
APP_ID=your_facebook_app_id_here
APP_SECRET=your_facebook_app_secret_here

# Server Configuration
PORT=3000
NODE_ENV=development
